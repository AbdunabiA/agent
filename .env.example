# LLM Provider API Keys
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
# GEMINI_API_KEY=your-key-here

# Claude Agent SDK (uses local subscription, no API key needed)
# AGENT_LLM_BACKEND=claude-sdk          # Switch default backend
# CLAUDE_AUTH_DIR=~/.claude              # Path to Claude auth directory
# CLAUDE_WORKING_DIR=.                   # Working directory for Claude Code
# CLAUDE_SDK_MODEL=                      # Override model (empty = default)
# CLAUDE_SDK_MAX_TURNS=50               # Max agent iterations per task
# CLAUDE_SDK_PERMISSION_MODE=            # null, acceptEdits, bypassPermissions

# Voice Settings
# VOICE_STT_PROVIDER=llm_native        # llm_native, whisper_api, whisper_local, deepgram
# VOICE_TTS_PROVIDER=edge_tts          # edge_tts, openai
# VOICE_TTS_VOICE=en-US-AriaNeural     # Edge TTS voice name
# VOICE_AUTO_REPLY=true                # Reply with voice to voice messages

# Telegram Bot (Phase 3)
# TELEGRAM_BOT_TOKEN=your-bot-token

# Gateway Auth (Phase 3)
# GATEWAY_TOKEN=your-secure-random-token

# GitHub API
# GITHUB_TOKEN=ghp_your-personal-access-token
# GITHUB_DEFAULT_OWNER=your-username
# GITHUB_DEFAULT_REPO=your-repo

# Email (Gmail App Password recommended)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# IMAP_HOST=imap.gmail.com
# EMAIL_ADDRESS=your-email@gmail.com
# EMAIL_PASSWORD=your-app-password
